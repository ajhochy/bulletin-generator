<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required for PyInstaller: Python interpreter needs unsigned executable memory -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Required for PyInstaller: bundled .dylibs are not individually signed by Apple -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Outbound network access for PCO API, Google Calendar, GitHub update checks -->
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
