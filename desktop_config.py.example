# Copy this file to desktop_config.py and fill in your credentials.
# desktop_config.py is gitignored — never commit your real credentials.
#
# Planning Center OAuth
# Register this redirect URI in your PCO developer app:
#   http://localhost:8765/oauth/pco/callback
PCO_CLIENT_ID = "your_pco_client_id_here"
PCO_CLIENT_SECRET = "your_pco_client_secret_here"
#
# Google Calendar OAuth
# Create a Web application OAuth client in Google Cloud Console.
# Enable the Google Calendar API, then add this authorized redirect URI:
#   http://localhost:8765/oauth/google/callback
GOOGLE_CLIENT_ID = "your_google_client_id_here"
GOOGLE_CLIENT_SECRET = "your_google_client_secret_here"
